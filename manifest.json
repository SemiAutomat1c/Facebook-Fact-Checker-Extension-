{
  "manifest_version": 3,
  "name": "VerifiAI Fact Check",
  "version": "1.0",
  "description": "Adds a Fact Check button to Facebook posts and comments.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["dom.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*.facebook.com/*"]
}